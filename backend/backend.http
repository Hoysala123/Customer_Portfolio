@backend_HostAddress = http://localhost:5167

GET {{backend_HostAddress}}/weatherforecast/
Accept: application/json

###
# ====================================
# ADMIN KYC ENDPOINTS
# ====================================

# GET all pending KYC requests
GET {{backend_HostAddress}}/api/admin/kyc/requests
Accept: application/json

###

# APPROVE a KYC request
POST {{backend_HostAddress}}/api/admin/kyc/{kyc_request_id_here}/approve
Content-Type: application/json

{}

###

# DECLINE a KYC request
POST {{backend_HostAddress}}/api/admin/kyc/{kyc_request_id_here}/decline
Content-Type: application/json

{}

